{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "@jgengine/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": [
    "src/game/config.ts",
    "src/game/palette.ts",
    "src/game/types.ts",
    "src/game/physics.ts",
    "src/game/table.ts",
    "src/game/sim.ts",
    "src/game/records.ts",
    "src/game/keybinds.ts",
    "src/game/content.ts",
    "src/game/store.ts",
    "src/loop.ts"
  ]
}
