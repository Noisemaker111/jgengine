{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "paths": {
      "@jgengine/shell/*": ["../../packages/shell/src/*"],
      "@jgengine/assets": ["../../packages/assets/src/index.ts"],
      "@jgengine/assets/*": ["../../packages/assets/src/*"],
      "@jgengine/core/*": ["../../packages/core/src/*"],
      "@jgengine/react/*": ["../../packages/react/src/*"],
      "@jgengine/ws/*": ["../../packages/ws/src/*"],
      "@games/world-of-warcraft": ["../../Games/world-of-warcraft/src/index.ts"],
      "@games/asset-showcase": ["../../Games/asset-showcase/src/index.tsx"],
      "@games/stress-bench": ["../../Games/stress-bench/src/index.tsx"],
      "@games/destruction-demo": ["../../Games/destruction-demo/src/index.tsx"]
    }
  },
  "include": ["src"]
}
