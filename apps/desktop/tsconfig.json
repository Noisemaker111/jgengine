{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "@/components/ui/*": [
        "../../registry/jgengine/*"
      ],
      "@jgengine/shell/*": [
        "../../packages/shell/src/*"
      ],
      "@jgengine/editor": [
        "../../packages/editor/src/index.ts"
      ],
      "@jgengine/editor/*": [
        "../../packages/editor/src/*"
      ],
      "@jgengine/assets": [
        "../../packages/assets/src/index.ts"
      ],
      "@jgengine/assets/*": [
        "../../packages/assets/src/*"
      ],
      "@jgengine/github": [
        "../../packages/github/src/index.ts"
      ],
      "@jgengine/github/*": [
        "../../packages/github/src/*"
      ],
      "@jgengine/core/*": [
        "../../packages/core/src/*"
      ],
      "@jgengine/react/*": [
        "../../packages/react/src/*"
      ],
      "@jgengine/ws/*": [
        "../../packages/ws/src/*"
      ],
      "@jgengine/convex/*": [
        "../../packages/convex/src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
