{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "cat .claude/fanout-reminder.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/warn-unpushed.mjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/papercut-reminder.mjs"
          }
        ]
      }
    ]
  }
}
