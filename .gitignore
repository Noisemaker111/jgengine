# CHANGELOG.md is authored once at the repo root and copied into each package
# at publish time (see publish.yml) +ÛGÈºG«• the per-package copies are build artifacts.
packages/*/CHANGELOG.md

# Compiled output must never sit beside TS source +ÛGÈºG«• Vite resolves .js over .ts,
# so a stray src/*.js silently shadows its .ts sibling and breaks dev/shoot.
# Source dirs are pure TypeScript; emit only ever goes to dist/.
packages/*/src/**/*.js
packages/*/src/**/*.jsx
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# Packaged skills and the API-surface JSON are staged from .claude/skills and
# packages/*/src by scripts/stage-skills.ts and scripts/gen-api-docs.ts +ÛGÈºG«•
# never author or commit these by hand.
packages/*/skills/
apps/web/src/generated/

# Ephemeral git worktrees created by fan-out shipping subagents
# (Agent({ isolation: "worktree" })) +ÛGÈºG«• transient, never committed.
.claude/worktrees/
