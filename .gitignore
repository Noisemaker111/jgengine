node_modules/
dist/
*.log
.DS_Store
shots/
.turbo/
**/public/models/*
!apps/dev/public/models/claudecraft/
!apps/dev/public/models/kaykit-adventurers/
!apps/dev/public/models/kaykit-city-builder/
!apps/dev/public/models/kaykit-dungeon/
!apps/dev/public/models/kaykit-furniture/
!apps/dev/public/models/quaternius-stylized-nature/
**/.jgengine-assets-tmp/
*.tsbuildinfo

# CHANGELOG.md is authored once at the repo root and copied into each package
# at publish time (see publish.yml) — the per-package copies are build artifacts.
packages/*/CHANGELOG.md

# Compiled output must never sit beside TS source — Vite resolves .js over .ts,
# so a stray src/*.js silently shadows its .ts sibling and breaks dev/shoot.
# Source dirs are pure TypeScript; emit only ever goes to dist/.
packages/*/src/**/*.js
packages/*/src/**/*.jsx
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# Packaged skills are staged from .claude/skills into packages/*/skills by
# scripts/stage-skills.ts — never author or commit these by hand.
packages/*/skills/

# Ephemeral git worktrees created by fan-out shipping subagents
# (Agent({ isolation: "worktree" })) — transient, never committed.
.claude/worktrees/
