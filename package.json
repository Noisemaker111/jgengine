{
  "name": "jgengine-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "Games/*",
    "apps/*",
    "examples/*",
    "registry"
  ],
  "scripts": {
    "build": "bun run --cwd packages/core build && bun run --cwd packages/ws build && bun run --cwd packages/sql build && bun run --cwd packages/react build && bun run --cwd packages/convex build && bun run --cwd packages/node build && bun run --cwd packages/shell build && bun run --cwd packages/assets build && bun run --cwd packages/github build && bun run --cwd packages/jgengine build && bun run build:registry",
    "check-artifacts": "bun scripts/check-no-src-artifacts.ts",
    "check-skills": "bun scripts/check-skill-sync.ts",
    "check-game-shape": "bun scripts/check-game-shape.ts",
    "check-types": "bun run check-artifacts && bun run check-skills && bun run check-game-shape && bun run --filter '*' check-types",
    "build:registry": "bun scripts/build-registry.ts",
    "gen-llms": "bun scripts/gen-llms-txt.ts",
    "check-llms": "bun scripts/gen-llms-txt.ts --check",
    "gen-api-docs": "bun scripts/gen-api-docs.ts",
    "test": "bun test packages Games apps/dev scripts",
    "dev": "bun run --cwd apps/web dev",
    "dev:runner": "bun run --cwd apps/dev dev",
    "shoot": "bun scripts/shoot-dev.ts",
    "papercut": "bun scripts/papercut.ts",
    "games:annals": "bun run --cwd Games/annals dev",
    "games:block-stacker": "bun run --cwd Games/block-stacker dev",
    "games:canyon-chase": "bun run --cwd Games/canyon-chase dev",
    "games:claudecraft": "bun run --cwd Games/claudecraft dev",
    "games:clockwork-heist": "bun run --cwd Games/clockwork-heist dev",
    "games:commit-canopy": "bun run --cwd Games/commit-canopy dev",
    "games:courier-zero": "bun run --cwd Games/courier-zero dev",
    "games:craterball": "bun run --cwd Games/craterball dev",
    "games:drift-district": "bun run --cwd Games/drift-district dev",
    "games:drone-derby": "bun run --cwd Games/drone-derby dev",
    "games:dune-nomads": "bun run --cwd Games/dune-nomads dev",
    "games:frostbite-circuit": "bun run --cwd Games/frostbite-circuit dev",
    "games:grid-tactics": "bun run --cwd Games/grid-tactics dev",
    "games:loop-station": "bun run --cwd Games/loop-station dev",
    "games:loot-shooter": "bun run --cwd Games/loot-shooter dev",
    "games:magnet-run": "bun run --cwd Games/magnet-run dev",
    "games:maze-muncher": "bun run --cwd Games/maze-muncher dev",
    "games:mine-drop": "bun run --cwd Games/mine-drop dev",
    "games:neon-shepherd": "bun run --cwd Games/neon-shepherd dev",
    "games:orbit-kart": "bun run --cwd Games/orbit-kart dev",
    "games:platform-hopper": "bun run --cwd Games/platform-hopper dev",
    "games:pulse-runner": "bun run --cwd Games/pulse-runner dev",
    "games:rail-rushers": "bun run --cwd Games/rail-rushers dev",
    "games:rooftop-relay": "bun run --cwd Games/rooftop-relay dev",
    "games:skyhook-rally": "bun run --cwd Games/skyhook-rally dev",
    "games:slingshot-siege": "bun run --cwd Games/slingshot-siege dev",
    "games:speed-circuit": "bun run --cwd Games/speed-circuit dev",
    "games:spire-cards": "bun run --cwd Games/spire-cards dev",
    "games:stormline": "bun run --cwd Games/stormline dev",
    "games:swarm-survivor": "bun run --cwd Games/swarm-survivor dev",
    "games:tideway": "bun run --cwd Games/tideway dev",
    "games:tower-guard": "bun run --cwd Games/tower-guard dev",
    "games:turbine-city": "bun run --cwd Games/turbine-city dev",
    "games:voxel-mine": "bun run --cwd Games/voxel-mine dev",
    "games:wreckway": "bun run --cwd Games/wreckway dev"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260705.1",
    "playwright-core": "^1.50.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8"
}
