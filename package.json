{
  "name": "jgengine",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "Games/*", "apps/*", "examples/*", "registry"],
  "scripts": {
    "build": "bun run --cwd packages/core build && bun run --cwd packages/ws build && bun run --cwd packages/sql build && bun run --cwd packages/react build && bun run --cwd packages/convex build && bun run --cwd packages/node build && bun run --cwd packages/shell build && bun run --cwd packages/assets build",
    "check-artifacts": "bun scripts/check-no-src-artifacts.ts",
    "check-skills": "bun scripts/check-skill-sync.ts",
    "check-game-shape": "bun scripts/check-game-shape.ts",
    "check-types": "bun run check-artifacts && bun run check-skills && bun run check-game-shape && bun run --filter '*' check-types",
    "build:registry": "bun scripts/build-registry.ts",
    "test": "bun test packages Games apps/dev scripts",
    "dev": "bun run --cwd apps/web dev",
    "dev:runner": "bun run --cwd apps/dev dev",
    "shoot": "bun scripts/shoot-dev.ts",
    "games:annals": "bun run --cwd Games/annals dev",
    "games:block-stacker": "bun run --cwd Games/block-stacker dev",
    "games:commit-canopy": "bun run --cwd Games/commit-canopy dev",
    "games:grid-tactics": "bun run --cwd Games/grid-tactics dev",
    "games:loot-shooter": "bun run --cwd Games/loot-shooter dev",
    "games:maze-muncher": "bun run --cwd Games/maze-muncher dev",
    "games:platform-hopper": "bun run --cwd Games/platform-hopper dev",
    "games:slingshot-siege": "bun run --cwd Games/slingshot-siege dev",
    "games:speed-circuit": "bun run --cwd Games/speed-circuit dev",
    "games:spire-cards": "bun run --cwd Games/spire-cards dev",
    "games:swarm-survivor": "bun run --cwd Games/swarm-survivor dev",
    "games:tower-guard": "bun run --cwd Games/tower-guard dev",
    "games:voxel-mine": "bun run --cwd Games/voxel-mine dev"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260705.1",
    "playwright-core": "^1.50.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8"
}
