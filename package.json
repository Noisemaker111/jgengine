{
  "name": "jgengine-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "Games/*",
    "apps/*",
    "examples/*",
    "registry"
  ],
  "scripts": {
    "build": "bun scripts/guard.ts 600 'bun scripts/ensure-ready.ts --install-only && bun run --cwd packages/core build && bun run --cwd packages/ws build && bun run --cwd packages/sql build && bun run --cwd packages/react build && bun run --cwd packages/convex build && bun run --cwd packages/node build && bun run --cwd packages/shell build && bun run --cwd packages/editor build && bun run --cwd packages/assets build && bun run --cwd packages/github build && bun run --cwd packages/jgengine build && bun run build:registry'",
    "check-artifacts": "bun scripts/check-no-src-artifacts.ts",
    "check-skills": "bun scripts/check-skill-sync.ts",
    "gen:skill-api": "bun scripts/gen-skill-api.ts",
    "check-skill-api": "bun scripts/gen-skill-api.ts --check",
    "check-game-shape": "bun scripts/check-game-shape.ts",
    "check-types": "bun scripts/guard.ts 900 'bun scripts/ensure-ready.ts && bun run check-artifacts && bun run check-skills && bun run check-skill-api && bun run check-game-shape && bun scripts/check-types-all.ts'",
    "build:registry": "bun scripts/build-registry.ts",
    "gen-llms": "bun scripts/gen-llms-txt.ts",
    "check-llms": "bun scripts/gen-llms-txt.ts --check",
    "gen-api-docs": "bun scripts/gen-api-docs.ts",
    "test": "bun scripts/guard.ts 300 'bun scripts/ensure-ready.ts && bun test packages apps/dev scripts'",
    "test:games": "bun scripts/guard.ts 900 'bun scripts/ensure-ready.ts && bun test Games'",
    "test:all": "bun scripts/guard.ts 900 'bun scripts/ensure-ready.ts && bun test packages Games apps/dev scripts'",
    "dev": "bun run --cwd apps/web dev",
    "dev:runner": "bun run --cwd apps/dev dev",
    "shoot": "bun scripts/guard.ts 300 'bun scripts/shoot-dev.ts'",
    "drive": "bun scripts/guard.ts 300 'bun scripts/drive-dev.ts'",
    "new:game": "bun scripts/new-game.ts",
    "host": "bun scripts/host-game.ts",
    "smoke": "bun scripts/guard.ts 600 'bun scripts/ensure-ready.ts && bun scripts/smoke-games.ts'",
    "papercut": "bun scripts/papercut.ts",
    "games:borderlands2": "bun run --cwd Games/borderlands2 dev",
    "games:canyon-chase": "bun run --cwd Games/canyon-chase dev",
    "games:claudecraft": "bun run --cwd Games/claudecraft dev",
    "games:clockwork-heist": "bun run --cwd Games/clockwork-heist dev",
    "games:craterball": "bun run --cwd Games/craterball dev",
    "games:drift-district": "bun run --cwd Games/drift-district dev",
    "games:drone-derby": "bun run --cwd Games/drone-derby dev",
    "games:dune-nomads": "bun run --cwd Games/dune-nomads dev",
    "games:frostbite-circuit": "bun run --cwd Games/frostbite-circuit dev",
    "games:grid-tactics": "bun run --cwd Games/grid-tactics dev",
    "games:loop-station": "bun run --cwd Games/loop-station dev",
    "games:loot-shooter": "bun run --cwd Games/loot-shooter dev",
    "games:magnet-run": "bun run --cwd Games/magnet-run dev",
    "games:monument": "bun run --cwd Games/monument dev",
    "games:neon-shepherd": "bun run --cwd Games/neon-shepherd dev",
    "games:nonogram": "bun run --cwd Games/nonogram dev",
    "games:orbit-kart": "bun run --cwd Games/orbit-kart dev",
    "games:pinball": "bun run --cwd Games/pinball dev",
    "games:pulse-runner": "bun run --cwd Games/pulse-runner dev",
    "games:rail-rushers": "bun run --cwd Games/rail-rushers dev",
    "games:road-hopper": "bun run --cwd Games/road-hopper dev",
    "games:rooftop-relay": "bun run --cwd Games/rooftop-relay dev",
    "games:skyhook-rally": "bun run --cwd Games/skyhook-rally dev",
    "games:spire-cards": "bun run --cwd Games/spire-cards dev",
    "games:star-invaders": "bun run --cwd Games/star-invaders dev",
    "games:tideway": "bun run --cwd Games/tideway dev",
    "games:tower-guard": "bun run --cwd Games/tower-guard dev",
    "games:turbine-city": "bun run --cwd Games/turbine-city dev",
    "games:vice-isle": "bun run --cwd Games/vice-isle dev",
    "games:wreckway": "bun run --cwd Games/wreckway dev"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260705.1",
    "playwright-core": "^1.50.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8"
}
