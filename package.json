{
  "name": "jgengine-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "Games/*",
    "apps/*",
    "examples/*",
    "registry"
  ],
  "scripts": {
    "build": "bun scripts/guard.ts 600 'bun scripts/ensure-ready.ts --install-only && bun run --cwd packages/core build && bun run --cwd packages/ws build && bun run --cwd packages/sql build && bun run --cwd packages/react build && bun run --cwd packages/convex build && bun run --cwd packages/node build && bun run --cwd packages/shell build && bun run --cwd packages/assets build && bun run --cwd packages/github build && bun run --cwd packages/jgengine build && bun run build:registry'",
    "check-artifacts": "bun scripts/check-no-src-artifacts.ts",
    "check-skills": "bun scripts/check-skill-sync.ts",
    "check-game-shape": "bun scripts/check-game-shape.ts",
    "check-types": "bun scripts/guard.ts 900 'bun scripts/ensure-ready.ts && bun run check-artifacts && bun run check-skills && bun run check-game-shape && bun run --filter \"*\" check-types'",
    "build:registry": "bun scripts/build-registry.ts",
    "gen-llms": "bun scripts/gen-llms-txt.ts",
    "check-llms": "bun scripts/gen-llms-txt.ts --check",
    "gen-api-docs": "bun scripts/gen-api-docs.ts",
    "test": "bun scripts/guard.ts 900 'bun scripts/ensure-ready.ts && bun test packages Games apps/dev scripts'",
    "dev": "bun run --cwd apps/web dev",
    "dev:runner": "bun run --cwd apps/dev dev",
    "shoot": "bun scripts/guard.ts 300 'bun scripts/shoot-dev.ts'",
    "papercut": "bun scripts/papercut.ts",
    "games:annals": "bun run --cwd Games/annals dev",
