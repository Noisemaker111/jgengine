{
  "name": "@jgengine/core",
  "version": "0.12.0",
  "description": "jgengine core — agent-first game framework SDK (npm @jgengine/core). Entity stores, commands, combat, inventory, multiplayer seams. Zero dependencies. Not an ECS. https://jgengine.com",
  "keywords": [
    "jgengine",
    "agent-first",
    "game-framework",
    "typescript-game-framework",
    "typescript",
    "multiplayer",
    "game-engine"
  ],
  "homepage": "https://jgengine.com",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./world": {
      "types": "./dist/world.d.ts",
      "default": "./dist/world.js"
    },
    "./combat": {
      "types": "./dist/combat.d.ts",
      "default": "./dist/combat.js"
    },
    "./gameplay": {
      "types": "./dist/gameplay.d.ts",
      "default": "./dist/gameplay.js"
    },
    "./multiplayer": {
      "types": "./dist/multiplayer.d.ts",
      "default": "./dist/multiplayer.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./procedural": {
      "types": "./dist/procedural.d.ts",
      "default": "./dist/procedural.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src"
  },
  "publishConfig": {
    "access": "public"
  }
}
