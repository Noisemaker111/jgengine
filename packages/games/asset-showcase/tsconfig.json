{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "paths": {
      "@jgengine/assets": ["../../assets/src/index.ts"],
      "@jgengine/assets/*": ["../../assets/src/*"],
      "@jgengine/core/*": ["../../core/src/*"],
      "@jgengine/react/*": ["../../react/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
