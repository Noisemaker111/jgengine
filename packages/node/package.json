{
  "name": "@jgengine/node",
  "version": "0.11.0",
  "description": "Standalone authoritative game host for JGengine: in-memory server snapshots, tick loop, save-cadence flush, WebSocket server, memory/file persistence.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/node"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src"
  },
  "dependencies": {
    "@jgengine/core": "^0.11.0",
    "@jgengine/ws": "^0.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@jgengine/sql": "workspace:*",
    "@types/node": "^24",
    "@types/ws": "^8",
    "pg-mem": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
