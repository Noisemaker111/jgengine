{
  "name": "jgengine",
  "version": "0.8.3",
  "description": "Agent-side CLI for JGengine. People build by telling an agent: Make a game that ... with jgengine. Agents use this CLI (create, skills, doctor, llms). Docs: https://jgengine.com",
  "keywords": [
    "game-engine",
    "typescript",
    "jgengine",
    "cli",
    "three.js",
    "agent",
    "scaffold"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://jgengine.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/jgengine"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "llms.txt"
  ],
  "bin": {
    "jgengine": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src"
  },
  "dependencies": {
    "@jgengine/assets": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^24"
  },
  "publishConfig": {
    "access": "public"
  }
}
