{
  "name": "@jgengine/shell",
  "version": "0.14.0",
  "description": "Game player shell for JGengine: React Three Fiber canvas, orbit camera, input tracking, HUD mounting, GameUiPreview, and a demo game. Consumers supply a GameRegistry.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/shell"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "skills"
  ],
  "exports": {
    "./camera": {
      "types": "./dist/camera/index.d.ts",
      "default": "./dist/camera/index.js"
    },
    "./defineGame": {
      "types": "./dist/defineGame.d.ts",
      "default": "./dist/defineGame.js"
    },
    "./GameHost": {
      "types": "./dist/GameHost.d.ts",
      "default": "./dist/GameHost.js"
    },
    "./gameKit": {
      "types": "./dist/gameKit.d.ts",
      "default": "./dist/gameKit.js"
    },
    "./GameUiPreview": {
      "types": "./dist/GameUiPreview.d.ts",
      "default": "./dist/GameUiPreview.js"
    },
    "./materialOverride": {
      "types": "./dist/materialOverride.d.ts",
      "default": "./dist/materialOverride.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./render/modelLoad": {
      "types": "./dist/render/modelLoad.d.ts",
      "default": "./dist/render/modelLoad.js"
    },
    "./render/modelRender": {
      "types": "./dist/render/modelRender.d.ts",
      "default": "./dist/render/modelRender.js"
    },
    "./render/resolveModel": {
      "types": "./dist/render/resolveModel.d.ts",
      "default": "./dist/render/resolveModel.js"
    },
    "./render/useModelAnimation": {
      "types": "./dist/render/useModelAnimation.d.ts",
      "default": "./dist/render/useModelAnimation.js"
    },
    "./shellMovement": {
      "types": "./dist/shellMovement.d.ts",
      "default": "./dist/shellMovement.js"
    },
    "./weather": {
      "types": "./dist/weather/index.d.ts",
      "default": "./dist/weather/index.js"
    },
    "./world/WorldHud": {
      "types": "./dist/world/WorldHud.d.ts",
      "default": "./dist/world/WorldHud.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "bun ../../scripts/check-types-preflight.ts && tsgo --noEmit -p tsconfig.json",
    "test": "bun test src"
  },
  "dependencies": {
    "@jgengine/core": "^0.14.0",
    "@jgengine/react": "^0.14.0",
    "@jgengine/ws": "^0.14.0"
  },
  "peerDependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "three": ">=0.170.0",
    "three-stdlib": "^2.0.0"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/react": "^19",
    "@types/three": "^0.182.0",
    "react": "19.2.3",
    "three": "^0.182.0",
    "three-stdlib": "^2.35.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
