{
  "name": "@jgengine/ws",
  "version": "0.14.0",
  "description": "Browser-safe WebSocket client backend for JGengine: protocol codec, createWsBackend, and HTTP read helpers.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/ws"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src"
  },
  "dependencies": {
    "@jgengine/core": "^0.14.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
