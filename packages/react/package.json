{
  "name": "@jgengine/react",
  "version": "0.7.0",
  "description": "React UI layer for JGengine: GameProvider, hooks, and headless primitives over @jgengine/core.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist",
    "check-types": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@jgengine/core": "^0.7.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "react": "19.2.3",
    "@types/react": "^19"
  },
  "publishConfig": {
    "access": "public"
  }
}
