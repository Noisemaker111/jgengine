{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@jgengine/core/*": [
        "../core/src/*"
      ],
      "@jgengine/react/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": ["src/**/*.test.ts"]
}
