{
  "name": "@jgengine/assets",
  "version": "0.14.0",
  "description": "Self-generating, license-verified index of thousands of CC0 3D models for JGengine. Sources fetch from providers' own CDNs at pull time; the npm tarball ships only the typed index and CLI (no GLB bytes).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noisemaker111/jgengine.git",
    "directory": "packages/assets"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "skills"
  ],
  "bin": {
    "assets": "dist/cli/pull.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && bun ../../scripts/fix-extensions.ts dist && bun scripts/postbuild.ts",
    "check-types": "bun ../../scripts/check-types-preflight.ts && tsgo --noEmit -p tsconfig.json",
    "gen:registry-catalog": "bun scripts/gen-registry-catalog.ts",
    "test": "bun test src"
  },
  "dependencies": {
    "@jgengine/core": "^0.14.0",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^24"
  },
  "publishConfig": {
    "access": "public"
  }
}
