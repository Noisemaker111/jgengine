{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [],
    "paths": {
      "@jgengine/core/*": [
        "../../packages/core/src/*"
      ],
      "@jgengine/convex/*": [
        "../../packages/convex/src/*"
      ]
    }
  },
  "include": [
    "convex"
  ],
  "exclude": [
    "convex/_generated",
    "convex/crons.ts"
  ]
}
