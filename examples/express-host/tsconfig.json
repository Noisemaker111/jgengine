{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "node"
    ],
    "paths": {
      "@jgengine/core/*": [
        "../../packages/core/src/*"
      ],
      "@jgengine/node/*": [
        "../../packages/node/src/*"
      ],
      "@jgengine/ws/*": [
        "../../packages/ws/src/*"
      ],
      "@jgengine/sql/*": [
        "../../packages/sql/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
