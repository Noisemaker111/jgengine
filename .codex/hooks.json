{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun '.codex/hooks/repetitive-edit-watch.mjs'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun '.codex/hooks/session-start.mjs'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun '.codex/hooks/warn-unpushed.mjs'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun '.codex/hooks/papercut-reminder.mjs'"
          }
        ]
      }
    ]
  }
}
